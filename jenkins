pipeline {
    agent any

    stages {

        stage('Clone') {
            steps {
                git 'https://github.com/Tarun-Motwani/Aboard-Management-System.git'
            }
        }

        stage('Install Backend') {
            steps {
                dir('server') {
                    bat 'npm install'
                }
            }
        }

        stage('Install Frontend') {
            steps {
                dir('client') {
                    bat 'npm install'
                }
            }
        }

        stage('Run Selenium Tests') {
            steps {
                dir('Aboard-Selenium-Tests') {
                    bat 'mvn clean test'
                }
            }
        }
    }
}